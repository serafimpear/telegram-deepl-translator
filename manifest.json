{
  "manifest_version": 3,
  "name": "Telegram DeepL Translator",
  "version": "1.0",
  "description": "Auto-translates Telegram Web messages using DeepL.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://web.telegram.org/*",
    "https://*.deepl.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://web.telegram.org/*"],
      "js": ["content.js"]
    }
  ]
}